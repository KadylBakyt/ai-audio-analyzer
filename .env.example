# ---------------------------------------------------------------------------
# AI Audio Analyzer — environment variables (LOCAL DEVELOPMENT ONLY)
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your key.
#
#   cp .env.example .env.local
#
# NOTE: Because this is a frontend-only app, any variable prefixed with VITE_
# is embedded into the client bundle and is therefore VISIBLE to end users.
# The recommended and default way to provide the key is via the in-app
# Settings page (stored only in the browser's localStorage, never committed).
#
# Use this env var ONLY for local development convenience.
# ---------------------------------------------------------------------------

# Your OpenAI API key (https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=

# Optional: override the API base URL (for OpenAI-compatible providers / proxies)
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override default models
VITE_OPENAI_TRANSCRIBE_MODEL=whisper-1
VITE_OPENAI_CHAT_MODEL=gpt-4o-mini
